{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/sw.js",
      "dest": "/home_inventory_backend/static/js/sw.js"
    },
    {
      "src": "/manifest.json",
      "dest": "/home_inventory_backend/static/manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ]
}
